<div class="visitor-flow-intelligence">
    <h2>{{ title|translate }}</h2>

    <p>
        {{ 'VisitorFlowIntelligence_ReportIntro'|translate }}
    </p>

    <p>
        <strong>{{ 'General_Website'|translate }}:</strong> {{ currentFilters.idSite }} |
        <strong>{{ 'General_Period'|translate }}:</strong> {{ currentFilters.period }} |
        <strong>{{ 'General_Date'|translate }}:</strong> {{ currentFilters.date }} |
        <strong>{{ 'VisitorFlowIntelligence_MaxDepth'|translate }}:</strong> {{ currentFilters.maxDepth }} |
        <strong>{{ 'General_Limit'|translate }}:</strong> {{ currentFilters.limit }}
    </p>

    {% if errorMessage %}
        <div class="alert alert-danger">
            {{ errorMessage }}
        </div>
    {% endif %}

    {% if payload %}
        <h3>{{ 'VisitorFlowIntelligence_TopPaths'|translate }}</h3>

        <table class="entityTable dataTable">
            <thead>
            <tr>
                <th>{{ 'VisitorFlowIntelligence_Path'|translate }}</th>
                <th>{{ 'General_ColumnNbVisits'|translate }}</th>
                <th>{{ 'VisitorFlowIntelligence_Share'|translate }}</th>
                <th>{{ 'VisitorFlowIntelligence_DropoffAtStep'|translate }}</th>
            </tr>
            </thead>
            <tbody>
            {% for row in payload.paths %}
                <tr>
                    <td>{{ row.steps|join(' -> ') }}</td>
                    <td>{{ row.visits }}</td>
                    <td>{{ (row.share * 100)|number_format(1, '.', '') }}%</td>
                    <td>{{ row.dropoffAtStep }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4">{{ 'General_NoDataForGraph'|translate }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <h3>{{ 'VisitorFlowIntelligence_TopTransitions'|translate }}</h3>

        <table class="entityTable dataTable">
            <thead>
            <tr>
                <th>{{ 'VisitorFlowIntelligence_Transition'|translate }}</th>
                <th>{{ 'General_ColumnNbVisits'|translate }}</th>
                <th>{{ 'VisitorFlowIntelligence_TransitionRate'|translate }}</th>
            </tr>
            </thead>
            <tbody>
            {% for row in payload.transitions %}
                <tr>
                    <td>{{ row.sourceStepId }} -> {{ row.targetStepId }}</td>
                    <td>{{ row.visits }}</td>
                    <td>{{ (row.transitionRate * 100)|number_format(1, '.', '') }}%</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3">{{ 'General_NoDataForGraph'|translate }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <h3>{{ 'VisitorFlowIntelligence_Dropoffs'|translate }}</h3>

        <table class="entityTable dataTable">
            <thead>
            <tr>
                <th>{{ 'VisitorFlowIntelligence_Path'|translate }}</th>
                <th>{{ 'VisitorFlowIntelligence_DropoffCount'|translate }}</th>
                <th>{{ 'VisitorFlowIntelligence_DropoffRate'|translate }}</th>
            </tr>
            </thead>
            <tbody>
            {% for row in payload.dropoffs %}
                <tr>
                    <td>{{ row.stepId }}</td>
                    <td>{{ row.dropoffCount }}</td>
                    <td>{{ (row.dropoffRate * 100)|number_format(1, '.', '') }}%</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3">{{ 'General_NoDataForGraph'|translate }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
